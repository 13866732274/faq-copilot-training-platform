APP_NAME=咨询话术模拟训练系统
DEBUG=false
# 本机 MySQL 时通常是 3306；如果使用 docker-compose.mysql8.yml 则端口是 33060
DATABASE_URL=mysql+asyncmy://user:password@127.0.0.1:33060/chattrainer
JWT_SECRET_KEY=please-change-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin123456

# 阿里云 DashScope / 百炼
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_COPILOT_MODEL=qwen-turbo
DASHSCOPE_COPILOT_BALANCED_MODEL=qwen-turbo
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_SCORING_RULE_WEIGHT=0.7
AI_SCORING_LLM_WEIGHT=0.3

# OpenClaw Webhook (微信自动回复)
BOT_WEBHOOK_SECRET=please-change-to-a-random-secret
FAQ_API_BASE=http://127.0.0.1:8000/api/v1
FAQ_BOT_USERNAME=wechat_bot
FAQ_BOT_PASSWORD=please-change
